{
  "name": "greenfield-engine-web",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Thin browser host for greenfield-engine (loads the Rust/WASM core).",
  "scripts": {
    "wasm": "wasm-pack build ../crates/engine --target web --out-dir \"$PWD/src/wasm\" --dev",
    "wasm:release": "wasm-pack build ../crates/engine --target web --out-dir \"$PWD/src/wasm\" --release",
    "dev": "npm run wasm && vite",
    "build": "npm run wasm:release && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.52",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
