{
  "name": "integrity-engine-web",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "description": "Thin browser host for Integrity (loads the Rust/WASM core).",
  "scripts": {
    "wasm": "wasm-pack build ../crates/engine --target web --out-dir \"$PWD/src/wasm\" --dev",
    "wasm:release": "wasm-pack build ../crates/engine --target web --out-dir \"$PWD/src/wasm\" --release",
    "dev": "npm run wasm && vite",
    "dev:lan": "npm run wasm && LAN=1 vite",
    "build": "npm run wasm:release && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@webgpu/types": "^0.1.52",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
